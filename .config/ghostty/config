config-file = ?~/.ghostty

background = 282E32
foreground = D3C6AA
cursor-color = D3C6AA
selection-background = 543A48
selection-foreground = D3C6AA

palette = 0=#232A2E
palette = 1=#E67E80
palette = 2=#A7C080
palette = 3=#DBBC7F
palette = 4=#7FBBB3
palette = 5=#D699B6
palette = 6=#83C092
palette = 7=#9DA9A0
palette = 8=#7A8478
palette = 9=#E67E80
palette = 10=#A7C080
palette = 11=#DBBC7F
palette = 12=#7FBBB3
palette = 13=#D699B6
palette = 14=#83C092
palette = 15=#D3C6AA

window-theme = "system"
shell-integration = fish

# Font settings
font-size = 13
#font-family = "JetBrainsMono Nerd Font"
macos-non-native-fullscreen = visible-menu
macos-option-as-alt = left
mouse-hide-while-typing = true

# Cursor settings
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor


# Cell Height
adjust-cell-height = 20%
grapheme-width-method = "unicode"

# Enable link on hover (MacOS: Cmd, Linux: Ctrl)
# Note: Under Tmux, require Shift + Cmd to open link
link-url = true

macos-option-as-alt = true
# Keybindings


# This doesn't help. Aerospace treats each ghostty tab as a separate window
# lead to when press alt+h/l, aerospace just change to the next/previous tab
# instead of select to the next window.
#keybind = alt+h=unbind
#keybind = alt+l=unbind

# Scrolling settings
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = shift+page_up=adjust_selection:page_up
keybind = shift+page_down=adjust_selection:page_down

shell-integration-features = ssh-terminfo,ssh-env
