config-file = ?~/.ghostty

window-theme = "system"
shell-integration = fish

# Gruvchad theme
palette = 0=#2d2f30
palette = 1=#d97368
palette = 2=#adb46a
palette = 3=#dbbf84
palette = 4=#89ada3
palette = 5=#c68a9c
palette = 6=#91af81
palette = 7=#bdb198
palette = 8=#414344
palette = 9=#d97368
palette = 10=#adb46a
palette = 11=#dbbf84
palette = 12=#89ada3
palette = 13=#c68a9c
palette = 14=#91af81
palette = 15=#c4b89f

background = #1f2122
foreground = #bdb198
selection-background = #414344
selection-foreground = #c4b89f
cursor-color = #dbbf84

# Font settings
font-size = 13
font-family = "DejavuSansM Nerd Font"
font-feature = -calt, -liga, -dlig
macos-non-native-fullscreen = visible-menu
macos-option-as-alt = left
mouse-hide-while-typing = true

# Cursor settings
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor


# Cell Height
adjust-cell-height = 20%
grapheme-width-method = "unicode"

# Enable link on hover (MacOS: Cmd, Linux: Ctrl)
# Note: Under Tmux, require Shift + Cmd to open link
link-url = true

macos-option-as-alt = true
# Keybindings


# This doesn't help. Aerospace treats each ghostty tab as a separate window
# lead to when press alt+h/l, aerospace just change to the next/previous tab
# instead of select to the next window.
#keybind = alt+h=unbind
#keybind = alt+l=unbind

# Scrolling settings
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = shift+page_up=adjust_selection:page_up
keybind = shift+page_down=adjust_selection:page_down

shell-integration-features = ssh-terminfo,ssh-env
