window-theme = "system"
shell-integration = fish
# theme = "nord"
# background-opacity = 0.97


background = #242933
foreground = #bbc3d4
selection-background = #1b1f26
selection-foreground = #bbc3d4
cursor-color = #bbc3d4
cursor-text = #191d24

palette = 0=#191d24
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#5e81ac
palette = 5=#b48ead
palette = 6=#8fbcbb
palette = 7=#bbc3d4
palette = 8=#3b4252
palette = 9=#c5727a
palette = 10=#b1c89d
palette = 11=#efd49f
palette = 12=#88c0d0
palette = 13=#be9d88
palette = 14=#9fc6c5
palette = 15=#d8dee9


# Font settings
font-family = "JetbrainsMono Nerd Font"
font-size = 13
font-thicken = false
font-thicken-strength = 0
font-feature=-calt

# Setting MacOs Titlebar
macos-titlebar-style = native

# Cursor settings
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor


# Cell Height
adjust-cell-height = 20%
grapheme-width-method = "unicode"

# Enable link on hover (MacOS: Cmd, Linux: Ctrl)
# Note: Under Tmux, require Shift + Cmd to open link
link-url = true

macos-option-as-alt = true
# Keybindings


# This doesn't help. Aerospace treats each ghostty tab as a separate window
# lead to when press alt+h/l, aerospace just change to the next/previous tab
# instead of select to the next window.
#keybind = alt+h=unbind
#keybind = alt+l=unbind

# Scrolling settings
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = shift+page_up=adjust_selection:page_up
keybind = shift+page_down=adjust_selection:page_down

shell-integration-features = ssh-terminfo,ssh-env
