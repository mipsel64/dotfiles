{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "agent": {
    "coder": {
      "description": "Primary coding agent using Claude Opus 4.6",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "debugger": {
      "description": "Debug and testing agent using GPT-5.1 Codex",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.3,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}

